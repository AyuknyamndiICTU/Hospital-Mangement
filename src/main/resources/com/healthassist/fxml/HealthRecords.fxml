<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.healthassist.controller.HealthRecordController"
            prefWidth="1200" prefHeight="800" styleClass="dashboard-root">
    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- SIDEBAR -->
        <VBox styleClass="sidebar" alignment="TOP_CENTER" spacing="8" prefWidth="70">
            <padding><Insets top="20" bottom="20"/></padding>
            <Label text="✚" styleClass="sidebar-logo"><font><Font size="24"/></font></Label>
            <Region prefHeight="30"/>
            <Button text="⌂" styleClass="sidebar-icon" onAction="#onNavHome"/>
            <Button text="📅" styleClass="sidebar-icon" onAction="#onNavAppointments"/>
            <Button text="👥" styleClass="sidebar-icon" onAction="#onNavPatients"/>
            <Button text="🩺" styleClass="sidebar-icon" onAction="#onNavDoctors"/>
            <Button text="📋" styleClass="sidebar-icon active" onAction="#onNavRecords"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="⏻" styleClass="sidebar-icon" onAction="#onLogout"/>
        </VBox>

        <!-- MAIN -->
        <VBox HBox.hgrow="ALWAYS" spacing="16" styleClass="main-content">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Health Records" styleClass="page-title">
                    <font><Font name="System Bold" size="24"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="patientCombo" promptText="Select Patient..." prefWidth="280" styleClass="login-input"/>
                <Button text="Load Records" styleClass="btn-primary" onAction="#onLoadRecords"/>
                <Button fx:id="addRecordBtn" text="+ Add Record" styleClass="btn-primary" onAction="#onAddRecord"/>
            </HBox>

            <!-- Timeline View -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="doctor-scroll">
                <HBox spacing="0">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                    <!-- Timeline line -->
                    <VBox fx:id="timelineLine" alignment="TOP_CENTER" prefWidth="40" minWidth="40">
                        <!-- Populated dynamically with circles and lines -->
                    </VBox>

                    <!-- Record Cards -->
                    <VBox fx:id="recordsBox" spacing="16" HBox.hgrow="ALWAYS">
                        <!-- Populated dynamically -->
                    </VBox>
                </HBox>
            </ScrollPane>
        </VBox>
    </HBox>
</AnchorPane>
